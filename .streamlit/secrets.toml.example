# DPAssist — Streamlit Cloud Secrets Template
# ──────────────────────────────────────────────────────────────────────
# In the Streamlit Cloud dashboard, go to your app → Settings → Secrets
# and paste the contents of this file with your real values filled in.
# DO NOT commit your real secrets.toml to GitHub.
# ──────────────────────────────────────────────────────────────────────

# Paste the ENTIRE contents of your service-account-credentials.json here
# as a single quoted string (no line breaks inside the string).
GOOGLE_CREDENTIALS_JSON = '{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}'

# Your Google Sheet ID (the long string in the sheet URL)
GOOGLE_SHEET_ID = "1bHU943lMaKwU0HjjwFoO0Dqcc1CB64-bZ5vuKhvWFbw"

# Gemini API key from Google AI Studio
GEMINI_API_KEY = "your-gemini-api-key"

# Gmail address where teacher drafts are created
TEACHER_EMAIL = "teacher@school.org"

# Gmail App Password (not your regular password — generate at myaccount.google.com/apppasswords)
GMAIL_APP_PASSWORD = "xxxx xxxx xxxx xxxx"

# Use Google Sheets for rubric storage (required on cloud — do not change this)
RUBRIC_STORAGE = "sheets"

# How often the background service checks for new submissions (seconds)
CHECK_INTERVAL_SECONDS = "60"
